# Clave de Groq (REQUERIDA) — obtén una gratis en https://console.groq.com
GROQ_API_KEY=gsk_...tu_clave_aqui

# Secreto compartido con el proxy del frontend (RECOMENDADO en producción).
# Si se define, el backend SOLO acepta peticiones con el header X-Internal-Secret
# igual a este valor. Genera uno con:  openssl rand -hex 32
# Ponlo IDÉNTICO en Railway (backend) y en Vercel (frontend). Nunca lo subas al repo.
BACKEND_SHARED_SECRET=

# Orígenes permitidos por CORS, coma-separado. En producción: https://tu-app.vercel.app
ALLOWED_ORIGINS=*

# Máximo de peticiones por IP por minuto (rate-limiting anti-abuso).
RATE_LIMIT_PER_MIN=30

# Límites de tamaño de la conversación (anti-abuso de tokens). Ajustables sin
# tocar código. MAX_TOTAL_LEN (suma de todo el historial) es el freno real de
# costo; el por-mensaje es generoso porque las respuestas del asistente son largas.
MAX_MSG_LEN=16000
MAX_MESSAGES=40
MAX_TOTAL_LEN=80000
